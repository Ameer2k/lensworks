generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  VENDOR
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id           String          @id @default(cuid())
  role         UserRole
  email        String          @unique
  passwordHash String
  fullName     String
  phone        String?
  avatarUrl    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  vendorProfile VendorProfile?
  clientBookings Booking[]     @relation("ClientBookings")
  vendorBookings Booking[]     @relation("VendorBookings")
  reviews      Review[]
  sentMessages Message[]       @relation("SentMessages")
}

model VendorProfile {
  id            String     @id @default(cuid())
  userId        String     @unique
  slug          String     @unique
  displayName   String
  bio           String?
  city          String?
  country       String?
  coverImageUrl String?
  ratingAvg     Float      @default(0)
  reviewCount   Int        @default(0)
  equipmentJson Json?
  stylesJson    Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id])
  packages      Package[]
  bookings      Booking[]
  reviews       Review[]
}

model Package {
  id              String         @id @default(cuid())
  vendorProfileId String
  name            String
  description     String?
  durationHours   Int?
  basePriceCents  Int
  deliverablesJson Json?
  isActive        Boolean        @default(true)
  vendorProfile   VendorProfile  @relation(fields: [vendorProfileId], references: [id])
  addOns          PackageAddon[]
}

model PackageAddon {
  id          String   @id @default(cuid())
  packageId   String
  name        String
  priceCents  Int
  isActive    Boolean  @default(true)
  package     Package  @relation(fields: [packageId], references: [id])
}

model Cart {
  id           String     @id @default(cuid())
  clientUserId String     @unique
  status       String     @default("ACTIVE")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  items        CartItem[]
}

model CartItem {
  id                  String   @id @default(cuid())
  cartId              String
  vendorProfileId     String
  packageId           String
  scheduledDate       DateTime?
  scheduledTime       String?
  venueAddress        String?
  note                String?
  packageSnapshotJson Json
  addonsSnapshotJson  Json?
  subtotalCents       Int
  serviceFeeCents     Int
  discountCents       Int      @default(0)
  totalCents          Int
  cart                Cart     @relation(fields: [cartId], references: [id])
}

model Booking {
  id             String        @id @default(cuid())
  clientUserId   String
  vendorUserId   String
  vendorProfileId String
  status         BookingStatus @default(PENDING)
  receiptNumber  String        @unique
  scheduledDate  DateTime?
  scheduledTime  String?
  venueAddress   String?
  note           String?
  subtotalCents  Int
  serviceFeeCents Int
  discountCents  Int           @default(0)
  totalCents     Int
  depositCents   Int
  balanceCents   Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  client         User          @relation("ClientBookings", fields: [clientUserId], references: [id])
  vendor         User          @relation("VendorBookings", fields: [vendorUserId], references: [id])
  vendorProfile  VendorProfile @relation(fields: [vendorProfileId], references: [id])
  payments       Payment[]
  reviews        Review[]
}

model Payment {
  id                      String        @id @default(cuid())
  bookingId               String
  provider                String
  providerPaymentIntentId String?
  amountCents             Int
  type                    String
  status                  PaymentStatus @default(PENDING)
  createdAt               DateTime      @default(now())
  booking                 Booking       @relation(fields: [bookingId], references: [id])
}

model Review {
  id             String        @id @default(cuid())
  bookingId      String
  clientUserId   String
  vendorProfileId String
  rating         Int
  body           String
  createdAt      DateTime      @default(now())
  booking        Booking       @relation(fields: [bookingId], references: [id])
  client         User          @relation(fields: [clientUserId], references: [id])
  vendorProfile  VendorProfile @relation(fields: [vendorProfileId], references: [id])
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderUserId   String
  body           String
  sentAt         DateTime      @default(now())
  readAt         DateTime?
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  sender         User          @relation("SentMessages", fields: [senderUserId], references: [id])
}

model Gallery {
  id           String         @id @default(cuid())
  bookingId    String         @unique
  title        String
  status       String         @default("DRAFT")
  assets       GalleryAsset[]
}

model GalleryAsset {
  id           String   @id @default(cuid())
  galleryId    String
  assetUrl     String
  thumbnailUrl String?
  isFavorite   Boolean  @default(false)
  sortOrder    Int      @default(0)
  gallery      Gallery  @relation(fields: [galleryId], references: [id])
}